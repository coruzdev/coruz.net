---
import { Icon } from 'astro-icon/components'

interface Props {
  question: string
  answer: Array<string>
}

const { question, answer } = Astro.props
---

<details
  name="faq"
  class="group border-muted/30 cursor-pointer border-b py-4 transition-all duration-300 outline-none hover:bg-white/5"
>
  <summary
    class="text-dark-primary group-open:text-accent flex items-center justify-between text-base font-medium transition-colors duration-300 sm:text-lg"
  >
    <span>{question}</span>
    <span class="ml-6 shrink-0 transition-transform duration-300 group-open:rotate-180">
      <Icon
        name="ep:arrow-down-bold"
        class="text-accent h-5 w-5 transform-[translateZ(0)] will-change-transform backface-hidden"
        aria-hidden="true"
      />
    </span>
  </summary>
  <div
    class="mt-4 flex max-h-0 flex-col gap-4 overflow-hidden text-sm leading-relaxed transition-all duration-300 group-open:max-h-96 sm:text-base"
  >
    {answer.map((item: string) => <p>{item}</p>)}
  </div>
</details>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }

  details[open] summary ~ * {
    animation: sweep 0.3s ease-in-out;
  }

  @keyframes sweep {
    0% {
      opacity: 0;
      transform: translateY(-10px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
