---
import { createContactURL } from '@/coruz.net.config'

import CTA from '@/components/CTA.astro'

interface Props {
  badge: string
  version: string
  description: string
  versionFeatures: string
  featuresExample: string
  ctaText: string
  ctaMessage: string
  isRecommended: boolean
}

const {
  badge,
  version,
  description,
  versionFeatures,
  featuresExample,
  ctaText,
  ctaMessage,
  isRecommended,
} = Astro.props
---

<div
  role="listitem"
  class:list={[
    'relative flex flex-col p-8',
    {
      'border border-white/10 bg-white/5': !isRecommended,
      'border-accent border-2 bg-white/5': isRecommended,
    },
  ]}
>
  {
    isRecommended && (
      <div class="bg-accent absolute -top-3.5 -right-0.5 px-4 py-1.5 text-[10px] font-black tracking-widest text-white uppercase">
        Recomendado
      </div>
    )
  }
  <div class="mb-6 flex grow flex-col items-center gap-4 text-center">
    <span class="bg-white/5 px-4 py-1.5 text-[10px] font-black tracking-widest uppercase">
      {badge}
    </span>
    <h5 class="text-light-primary text-3xl font-bold">{version}</h5>
    <p class="max-w-11/12 text-base leading-relaxed">
      {description}
    </p>
  </div>
  <div class="mb-8 flex flex-col justify-center">
    <div class="flex flex-col items-center gap-3 border border-white/10 bg-white/5 p-6 text-center">
      <p class="text-sm">
        <span class="mb-2 block leading-tight font-bold">{versionFeatures}</span>
        <span class="block font-medium">{featuresExample}</span>
      </p>
    </div>
  </div>
  {isRecommended && <CTA text={ctaText} message={ctaMessage} />}
  {
    !isRecommended && (
      <a
        class="text-light-primary font-display border border-white/20 bg-transparent px-4 py-2 text-center text-base font-medium transition-all duration-300 outline-none hover:bg-white/5 focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 md:text-lg"
        href={createContactURL('w', ctaMessage)}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${ctaText} (abre WhatsApp en una nueva pestaña)`}
      >
        {ctaText}
      </a>
    )
  }
</div>
