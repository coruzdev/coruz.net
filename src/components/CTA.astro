---
import { createContactURL } from '@/coruz.net.config'

interface Props {
  text: string
  message: string
  class?: string
}

const { text, message, class: className } = Astro.props
---

<a
  class:list={[
    'bg-accent hover:bg-accent/90 font-display focus-visible:ring-accent px-4 py-2 text-center text-base font-medium text-white transition-all duration-300 outline-none hover:text-white/90 focus-visible:ring-2 focus-visible:ring-offset-2 md:text-lg',
    className,
  ]}
  href={createContactURL('w', message)}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`${text} (abre WhatsApp en una nueva pestaña)`}>{text}</a
>
