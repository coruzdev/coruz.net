---
import { Icon } from 'astro-icon/components'

interface Props {
  icon: string
  title: string
  description: string
}
const { icon, title, description } = Astro.props
---

<div class="flex flex-col gap-4" role="listitem">
  <Icon
    name={icon}
    class="text-dark h-10 w-10 transform-[translateZ(0)] will-change-transform backface-hidden"
    aria-hidden="true"
  />
  <div>
    <h5 class="text-dark-primary mb-2 text-lg font-bold sm:text-xl">{title}</h5>
    <p class="text-sm leading-relaxed sm:text-base">
      {description}
    </p>
  </div>
</div>
