---
import { Icon } from 'astro-icon/components'

import { CONTACT_INFO, createContactURL } from '@/coruz.net.config'
---

<footer class="bg-dark text-light-primary w-full">
  <div class="main-container flex flex-wrap gap-x-10 py-10">
    <div
      class="border-light-secondary flex w-full flex-col items-center justify-center gap-4 border-b pb-10 text-center lg:flex-2 lg:items-start lg:border-none lg:pb-0 lg:text-left"
    >
      <Icon
        name="white-logo-coruz"
        class="h-16 w-16 transform-[translateZ(0)] will-change-transform backface-hidden md:h-20 md:w-20 lg:-ml-2"
        aria-hidden="true"
      />
      <h4 class="text-lg leading-snug font-bold md:text-xl">
        <span class="font-logo -mt-2 mb-2 block lg:inline">CORUZ</span>
        <span class="hidden lg:inline"> -</span> Diseño y Desarrollo de Páginas Web en México
      </h4>
      <p class="text-sm leading-relaxed md:text-base">
        Diseñamos y desarrollamos páginas web modernas, seguras y funcionales para profesionales y
        negocios en México.
      </p>
    </div>
    <div
      class="border-light-secondary flex w-full flex-col items-center justify-center border-b pt-10 pb-10 text-center sm:flex-1 sm:border-none sm:pb-0 lg:pt-0"
    >
      <nav aria-labelledby="footer-menu-heading">
        <h5 id="footer-menu-heading" class="mb-5 text-base font-bold md:text-lg">Menú</h5>
        <ul class="text-sm md:text-base">
          <li class="hover:text-light-secondary">
            <a
              href="/#home"
              class="focus-visible:ring-light-primary block py-1 outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
              >Inicio</a
            >
          </li>
          <li class="hover:text-light-secondary">
            <a
              href="/#about-us"
              class="focus-visible:ring-light-primary block py-1 outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
              >Nosotros</a
            >
          </li>
          <li class="hover:text-light-secondary">
            <a
              href="/#services"
              class="focus-visible:ring-light-primary block py-1 outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
              >Servicios</a
            >
          </li>
          <li class="hover:text-light-secondary">
            <a
              href="/#faq"
              class="focus-visible:ring-light-primary block py-1 outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
              >FAQ</a
            >
          </li>
        </ul>
      </nav>
    </div>
    <div class="flex w-full flex-col items-center justify-center pt-10 sm:flex-1 lg:pt-0">
      <h5 id="footer-contact-heading" class="mb-5 text-base font-bold md:text-lg">Contáctanos</h5>
      <ul class="flex flex-col items-center" aria-labelledby="footer-contact-heading">
        <li>
          <a
            class="hover:text-light-secondary focus-visible:ring-light-primary flex items-center gap-1 py-1 text-sm outline-none focus-visible:ring-2 focus-visible:ring-offset-2 md:text-base"
            href={createContactURL('w')}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Enviar mensaje por WhatsApp al número ${CONTACT_INFO.whatsAppNumber} (abre WhatsApp en una nueva pestaña)`}
          >
            <Icon
              name="garden:whatsapp-fill-12"
              aria-hidden="true"
              class="h-3 w-3 transform-[translateZ(0)] will-change-transform backface-hidden md:h-4 md:w-4"
            />
            {CONTACT_INFO.whatsAppNumberFormatted}
          </a>
        </li>
        <li>
          <a
            class="hover:text-light-secondary focus-visible:ring-light-primary flex items-center gap-1 py-1 text-sm outline-none focus-visible:ring-2 focus-visible:ring-offset-2 md:text-base"
            href={createContactURL('e-info')}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Enviar correo electrónico a ${CONTACT_INFO.infoEmail} (abre el cliente de correo)`}
          >
            <Icon
              name="mdi:envelope"
              aria-hidden="true"
              class="h-4 w-4 transform-[translateZ(0)] will-change-transform backface-hidden md:h-5 md:w-5"
            />
            {CONTACT_INFO.infoEmail}
          </a>
        </li>
      </ul>
    </div>
  </div>
  <div
    class="main-container border-light-secondary flex flex-col items-center gap-2 border-t py-4 text-sm sm:flex-row sm:justify-between md:text-base"
  >
    <p>
      <a
        class="hover:text-light-secondary focus-visible:ring-light-primary underline outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
        href="/aviso-de-privacidad">Aviso de Privacidad</a
      >
    </p>
    <p>Copyright &copy; {new Date().getFullYear()} CORUZ</p>
  </div>
</footer>
