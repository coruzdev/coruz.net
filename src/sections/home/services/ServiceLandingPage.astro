---
import { Icon } from 'astro-icon/components'

import LandingPageCard from '@/components/LandingPageCard.astro'

const sharedFeatures = [
  {
    text: 'Estructura de una sola página',
    icon: 'streamline:layout-window-2',
  },
  {
    text: 'Diseño adaptable y moderno',
    icon: 'streamline-ultimate:responsive-design',
  },
  {
    text: 'Contacto directo por WhatsApp',
    icon: 'garden:whatsapp-stroke-12',
  },
  {
    text: 'Conexión a redes sociales',
    icon: 'tabler:social',
  },
  {
    text: 'Ubicación en Google Maps',
    icon: 'hugeicons:maps-square-01',
  },
  {
    text: 'Carga y velocidad optimizada',
    icon: 'material-symbols:speed-outline',
  },
  {
    text: 'Posicionamiento en IA',
    icon: 'hugeicons:ai-search',
  },
  {
    text: 'Alojamiento web',
    icon: 'uil:server',
  },
  {
    text: 'Seguridad y certificado SSL',
    icon: 'material-symbols:security-rounded',
  },
]
const cardsData = [
  {
    badge: 'PRESENCIA',
    version: 'Lite',
    description:
      'Tu negocio en internet hoy mismo. La opción ideal para validar tu idea de mercado con una inversión mínima.',
    versionFeatures: 'Subdominio gestionado por CORUZ',
    featuresExample: '(tunegocio.coruz.net)',
    CTAText: 'Empezar con Lite',
    CTAMessage: 'Buen día, quiero cotizar una landing page lite, ¿me podrían enviar información?',
    isRecommended: false,
  },
  {
    badge: 'IDENTIDAD',
    version: 'Standard',
    description:
      'Posiciona tu marca con autoridad. El estándar profesional para empresas que buscan proyectar confianza, seriedad y control total sobre su presencia digital.',
    versionFeatures: 'Dominio .com propio y correo profesional',
    featuresExample: '(tunegocio.com)',
    CTAText: '¡Quiero la Standard!',
    CTAMessage:
      'Buen día, quiero cotizar una landing page standard, ¿me podrían enviar información?',
    isRecommended: true,
  },
]
---

<div id="landing-page" class="dark-section pb-32" aria-labelledby="lp-title">
  <div class="main-container">
    <h3
      id="lp-title"
      class="text-light-primary mx-auto mb-6 w-full text-center text-3xl leading-tight font-bold sm:text-4xl xl:w-2/3"
    >
      Landing Page
    </h3>
    <p class="mx-auto max-w-5xl text-center text-base leading-relaxed sm:text-lg">
      La forma más rápida y efectiva de convertir visitas en clientes. Diseñamos una estructura
      estratégica de navegación continua que guía al usuario directamente hacia el objetivo:
      contactarte o comprar.
    </p>
    <div class="mx-auto mt-20 mb-16 max-w-5xl border border-white/10 bg-white/5 p-8 md:p-12">
      <h4 class="text-light-primary mb-10 text-center text-lg leading-tight font-bold sm:text-xl">
        Lo que incluye tu Landing Page:
      </h4>

      <div class="grid grid-cols-1 gap-x-12 gap-y-8 sm:grid-cols-2 lg:grid-cols-3" role="list">
        {
          sharedFeatures.map((feature) => (
            <div class="flex items-center gap-4" role="listitem">
              <Icon
                name={feature.icon}
                class="text-accent h-5 w-5 shrink-0 transform-[translateZ(0)] will-change-transform backface-hidden sm:h-6 sm:w-6"
                aria-hidden="true"
              />
              <p class="text-sm leading-tight sm:text-base">{feature.text}</p>
            </div>
          ))
        }
      </div>
    </div>
    <div
      class="mx-auto grid max-w-5xl grid-cols-1 items-stretch gap-8 md:grid-cols-2 lg:gap-12"
      role="list"
    >
      {
        cardsData.map((card) => (
          <LandingPageCard
            badge={card.badge}
            version={card.version}
            description={card.description}
            versionFeatures={card.versionFeatures}
            featuresExample={card.featuresExample}
            ctaText={card.CTAText}
            ctaMessage={card.CTAMessage}
            isRecommended={card.isRecommended}
          />
        ))
      }
    </div>
  </div>
</div>
