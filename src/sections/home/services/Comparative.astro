---
import { Icon } from 'astro-icon/components'

import CTA from '@/components/CTA.astro'
import ComparativeFeature from '@/components/ComparativeFeature.astro'

const servicesFeatures = [
  {
    feature: 'Estructura multi-página',
    LPL: false,
    LPS: false,
    FW: true,
  },
  {
    feature: 'Diseño adaptable y moderno',
    LPL: true,
    LPS: true,
    FW: true,
  },
  {
    feature: 'Carga y velocidad optimizada',
    LPL: true,
    LPS: true,
    FW: true,
  },
  {
    feature: 'Posicionamiento en buscadores y asistentes de IA',
    LPL: true,
    LPS: true,
    FW: true,
  },
  {
    feature: 'Conexión a redes sociales',
    LPL: true,
    LPS: true,
    FW: true,
  },
  {
    feature: 'Contacto directo por WhatsApp',
    LPL: true,
    LPS: true,
    FW: true,
  },
  {
    feature: 'Ubicación interactiva en Google Maps',
    LPL: true,
    LPS: true,
    FW: true,
  },
  {
    feature: 'Correo electrónico profesional',
    LPL: false,
    LPS: true,
    FW: true,
  },
  {
    feature: 'Alojamiento web',
    LPL: true,
    LPS: true,
    FW: true,
  },
  {
    feature: 'Subdominio gestionado por CORUZ',
    LPL: true,
    LPS: false,
    FW: false,
  },
  {
    feature: 'Dominio .com propio',
    LPL: false,
    LPS: true,
    FW: true,
  },
  {
    feature: 'Seguridad y certificado SSL',
    LPL: true,
    LPS: true,
    FW: true,
  },
]
---

<section id="comparative" class="light-section py-32" aria-labelledby="comparative-title">
  <div class="main-container">
    <h2 class="text-accent mb-8 text-center text-sm font-black tracking-widest uppercase">
      COMPARATIVA
    </h2>
    <h3
      id="comparative-title"
      class="text-dark-primary mx-auto mb-6 w-full text-center text-3xl leading-tight font-bold sm:text-4xl xl:w-2/3"
    >
      Elige la solución que mejor se adapta a tu negocio
    </h3>
    <p class="text-center text-base leading-relaxed sm:text-lg">
      Diseño y desarrollo de páginas web profesionales en México.
    </p>
    <div class="mt-20" role="table">
      <div
        class="border-muted grid w-full grid-cols-2 border-b lg:grid-cols-[40%_30%_30%]"
        role="row"
      >
        <h4
          class="text-dark-primary hidden items-end justify-start py-5 text-lg leading-tight font-bold sm:text-xl lg:flex"
          role="columnheader"
        >
          Características
        </h4>
        <div
          class="flex flex-col items-center justify-start gap-3 bg-white pt-5 text-center"
          role="columnheader"
        >
          <Icon
            name="landing-page"
            class="text-dark h-16 w-16 transform-[translateZ(0)] will-change-transform backface-hidden sm:h-20 sm:w-20"
            aria-hidden="true"
          />
          <h4 class="text-dark-primary text-lg leading-tight font-bold sm:text-xl">Landing Page</h4>
          <p class="mb-2 px-5 text-sm leading-relaxed sm:text-base">
            La solución más rápida para tener presencia y captar clientes.
          </p>
          <div class="border-muted flex w-full border-t">
            <h5
              class="border-muted text-dark-primary flex-1 border-r py-5 text-sm leading-tight font-bold sm:text-base"
            >
              Lite
            </h5>
            <h5 class="text-dark-primary flex-1 py-5 text-sm leading-tight font-bold sm:text-base">
              Estándar
            </h5>
          </div>
        </div>
        <div
          class="flex flex-col items-center justify-start gap-3 py-5 text-center"
          role="columnheader"
        >
          <Icon
            name="full-web"
            class="text-dark h-16 w-16 transform-[translateZ(0)] will-change-transform backface-hidden sm:h-20 sm:w-20"
            aria-hidden="true"
          />
          <h4 class="text-dark-primary text-lg leading-tight font-bold sm:text-xl">Full Web</h4>
          <p class="px-5 text-sm leading-relaxed sm:text-base">
            Estructura robusta y escalable para máxima autoridad en tu sector.
          </p>
        </div>
      </div>
      {
        servicesFeatures.map((elemento) => (
          <ComparativeFeature
            feature={elemento.feature}
            LPL={elemento.LPL}
            LPS={elemento.LPS}
            FW={elemento.FW}
          />
        ))
      }
      <div class="grid w-full grid-cols-2 lg:grid-cols-[40%_30%_30%]">
        <div class="hidden lg:block"></div>
        <div class="flex items-center justify-center bg-white px-6 py-16">
          <CTA
            text="¡Quiero una Landing Page!"
            message="Buen día, quiero cotizar una landing page, ¿me podrían enviar información?"
          />
        </div>
        <div class="flex items-center justify-center px-6 py-16">
          <CTA
            text="¡Quiero una Full Web!"
            message="Buen día, quiero cotizar una full web, ¿me podrían enviar información?"
          />
        </div>
      </div>
      <p
        class="text-muted mx-auto mt-12 max-w-4xl text-center text-xs leading-relaxed italic sm:text-sm"
      >
        <strong>Nota:</strong> Los servicios de infraestructura digital se incluyen sin costo por un periodo
        de 12 meses. Al término de este plazo, será necesaria su renovación anual al precio vigente para
        mantener la operatividad de tu sitio.
      </p>
    </div>
  </div>
</section>
