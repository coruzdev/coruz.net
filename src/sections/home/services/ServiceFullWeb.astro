---
import { Icon } from 'astro-icon/components'
import FullWebHighlight from '@/components/FullWebHighlight.astro'
import { createContactURL } from '@/coruz.net.config'

const features = [
  {
    text: 'Estructura multi-página',
    icon: 'streamline-ultimate:app-window-multiple',
  },
  {
    text: 'Diseño adaptable y moderno',
    icon: 'streamline-ultimate:responsive-design',
  },
  {
    text: 'Contacto directo por WhatsApp',
    icon: 'garden:whatsapp-stroke-12',
  },
  {
    text: 'Conexión a redes sociales',
    icon: 'tabler:social',
  },
  {
    text: 'Ubicación en Google Maps',
    icon: 'hugeicons:maps-square-01',
  },
  {
    text: 'Carga y velocidad optimizada',
    icon: 'material-symbols:speed-outline',
  },
  {
    text: 'Posicionamiento en IA',
    icon: 'hugeicons:ai-search',
  },
  {
    text: 'Alojamiento web',
    icon: 'uil:server',
  },
  {
    text: 'Dominio .com propio',
    icon: 'stash:domain',
  },
  {
    text: 'Correo profesional',
    icon: 'entypo:email',
  },
  {
    text: 'Seguridad y certificado SSL',
    icon: 'material-symbols:security-rounded',
  },
]

const highlights = [
  {
    title: 'Desde 4 páginas esenciales',
    description:
      'Incluye Inicio, Nosotros, Servicios y Contacto con una navegación intuitiva y profesional.',
  },
  {
    title: 'Posicionamiento Avanzado',
    description:
      'Optimización profunda orientada a resultados en buscadores y asistentes de IA (LLMs) para dominar tu sector.',
  },
  {
    title: 'Diseño de Alto Perfil',
    description:
      'Identidad visual robusta y contenido estructurado estratégicamente para comunicar tu propuesta de valor de forma impecable.',
  },
  {
    title: 'Escalabilidad Total',
    description:
      'Estructura preparada para crecer. Añadimos las secciones o funcionalidades que tu negocio necesite en el futuro.',
  },
]
---

<div class="light-section py-32" aria-labelledby="fw-title">
  <div class="main-container">
    <div class="border-light-primary shadow-dark/5 border bg-white p-12 shadow-2xl md:p-20">
      <div class="grid grid-cols-1 items-start gap-12 pb-6 lg:grid-cols-[2fr_1fr]">
        <div>
          <span
            class="bg-accent/10 text-accent mb-4 inline-block px-4 py-1.5 text-[10px] font-black tracking-widest uppercase"
          >
            AUTORIDAD
          </span>
          <h3
            id="fw-title"
            class="text-dark-primary mb-6 text-3xl leading-tight font-bold sm:text-4xl"
          >
            Full Web
          </h3>
          <p class="mb-10 text-base leading-relaxed sm:text-lg">
            Sitio web profesional multi-página con una estructura robusta y escalable. Diseñado para
            negocios que buscan organizar su catálogo de servicios, proyectar máxima autoridad y
            centralizar toda su operación digital.
          </p>
          <div class="grid grid-cols-1 gap-x-12 gap-y-8 md:grid-cols-2" role="list">
            {
              features.map((feature) => (
                <div class="flex items-center gap-4" role="listitem">
                  <Icon
                    name={feature.icon}
                    class="text-accent h-5 w-5 shrink-0 transform-[translateZ(0)] will-change-transform backface-hidden sm:h-6 sm:w-6"
                    aria-hidden="true"
                  />
                  <p class="text-sm leading-tight sm:text-base">{feature.text}</p>
                </div>
              ))
            }
          </div>
        </div>
        <div class="flex flex-col gap-6" role="list" aria-label="Puntos destacados">
          {
            highlights.map((feature) => (
              <FullWebHighlight title={feature.title} description={feature.description} />
            ))
          }
        </div>
      </div>
      <div class="border-light-primary flex flex-col items-start gap-6 border-t pt-6">
        <p class="text-muted text-xs sm:text-sm">
          ¿Necesitas algo más complejo? Personalizamos cada detalle.
        </p>
        <a
          class="bg-dark hover:bg-dark/90 text-light-primary hover:text-light-primary/90 font-display focus-visible:ring-dark px-4 py-2 text-center text-base font-medium transition-all duration-300 outline-none focus-visible:ring-2 focus-visible:ring-offset-2 md:text-lg"
          href={createContactURL(
            'w',
            'Buen día, quiero cotizar una full web, ¿me podrían enviar información?'
          )}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Cotizar Full Web (abre WhatsApp en una nueva pestaña)"
        >
          Cotizar Full Web
        </a>
      </div>
    </div>
  </div>
</div>
